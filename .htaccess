# ============================================================
#  Magnum Torque - Configuracao Apache
# ============================================================

# Pagina de erro 404 personalizada
ErrorDocument 404 /404.html

# Define a pagina inicial
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ---- HTTPS + www canonico ---------------------------------
  # Forca HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L,NE]

  # Forca www (canonico)
  RewriteCond %{HTTP_HOST} ^magnumtorque\.com\.br$ [NC]
  RewriteRule ^ https://www.magnumtorque.com.br%{REQUEST_URI} [R=301,L,NE]

  # ---- Rewrite de subpaginas legado para ancoras do SPA -----
  # Permite que /sobre, /contato, /servicos, etc. redirecionem
  # para a secao correspondente na home
  RewriteRule ^(inicio|home|index)/?$ / [R=301,L,NE]
  RewriteRule ^(sobre|about|empresa|quem-somos)/?$ /#sobre [R=301,L,NE]
  RewriteRule ^(servicos|services|retifica|conversor|conversores)/?$ /#servicos [R=301,L,NE]
  RewriteRule ^(pecas|parts|produtos)/?$ /#pecas [R=301,L,NE]
  RewriteRule ^(parceiros|partners|marcas)/?$ /#parceiros [R=301,L,NE]
  RewriteRule ^(depoimentos|testimonials|avaliacoes)/?$ /#depoimentos [R=301,L,NE]
  RewriteRule ^(faq|duvidas|perguntas)/?$ /#faq [R=301,L,NE]
  RewriteRule ^(contato|contact|orcamento|fale-conosco)/?$ /#contato [R=301,L,NE]
</IfModule>

# ============================================================
#  Performance e cache
# ============================================================

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                                      "access plus 1 month"

  # HTML sempre fresco
  ExpiresByType text/html                             "access plus 0 seconds"

  # Assets com cache longo
  ExpiresByType text/css                              "access plus 1 year"
  ExpiresByType application/javascript                "access plus 1 year"
  ExpiresByType image/webp                            "access plus 1 year"
  ExpiresByType image/png                             "access plus 1 year"
  ExpiresByType image/jpeg                            "access plus 1 year"
  ExpiresByType image/svg+xml                         "access plus 1 year"
  ExpiresByType image/x-icon                          "access plus 1 year"

  # Fontes
  ExpiresByType font/woff2                            "access plus 1 year"
  ExpiresByType font/woff                             "access plus 1 year"

  # SEO
  ExpiresByType text/xml                              "access plus 1 day"
  ExpiresByType application/xml                       "access plus 1 day"
  ExpiresByType text/plain                            "access plus 1 day"
</IfModule>

# Garante MIME types corretos (alguns hosts nao tem por padrao)
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg .svgz
  AddType application/manifest+json .webmanifest
  AddType text/plain .txt
</IfModule>

# ============================================================
#  Seguranca
# ============================================================

<IfModule mod_headers.c>
  # HSTS (ignorado pelo browser em HTTP, seguro emitir sempre)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # Clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"
  # MIME sniffing
  Header always set X-Content-Type-Options "nosniff"
  # Referrer
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Permissoes
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=(), browsing-topics=(), attribution-reporting=()"
  # Cross-Origin
  Header always set Cross-Origin-Opener-Policy "same-origin"
</IfModule>

# Permite o diretorio .well-known (Let's Encrypt, etc.)
<IfModule mod_alias.c>
  RedirectMatch 403 ^/\.(?!well-known/).*
</IfModule>

# Bloqueia acesso a arquivos ocultos, exceto .well-known
<FilesMatch "^\.(?!well-known)">
  Require all denied
</FilesMatch>

<FilesMatch "\.(md|log|yml|yaml|json|lock)$">
  Require all denied
</FilesMatch>

# Whitelist: indice de busca do blog (consumido via fetch pelo JS)
<Files "search-index.json">
  Require all granted
  Header set Cache-Control "public, max-age=3600"
</Files>

# Permite robots.txt, sitemap, humans.txt
<Files "robots.txt">
  Require all granted
</Files>
<Files "sitemap.xml">
  Require all granted
</Files>
<Files "humans.txt">
  Require all granted
</Files>

# security.txt dentro de .well-known (forca text/plain)
<IfModule mod_headers.c>
  <Files "security.txt">
    Header set Content-Type "text/plain; charset=utf-8"
  </Files>
</IfModule>
